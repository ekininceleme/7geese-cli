{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/exportOutput",
  "$defs": {
    "exportOutput": {
      "properties": {
        "exported_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of when this export was generated"
        },
        "me": {
          "$ref": "#/$defs/exportProfile",
          "description": "The authenticated user's full profile and history"
        },
        "direct_reports": {
          "items": {
            "$ref": "#/$defs/exportProfile"
          },
          "type": "array",
          "description": "Direct reports with the same data shape as me"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "exported_at",
        "me"
      ]
    },
    "exportProfile": {
      "properties": {
        "profile": {
          "$ref": "#/$defs/exportUser",
          "description": "User profile information"
        },
        "objectives": {
          "items": {
            "$ref": "#/$defs/exportObjective"
          },
          "type": "array",
          "description": "OKRs where the user is an owner, stakeholder, or follower"
        },
        "oneonones": {
          "items": {
            "$ref": "#/$defs/exportMeeting"
          },
          "type": "array",
          "description": "1:1 meeting history with full Q&A from both participants (only present on me, not direct_reports)"
        },
        "recognitions": {
          "$ref": "#/$defs/exportRecognition",
          "description": "Recognition badges sent and received"
        },
        "reviews": {
          "items": {
            "$ref": "#/$defs/exportReview"
          },
          "type": "array",
          "description": "Completed performance review cycles"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "profile",
        "objectives",
        "recognitions",
        "reviews"
      ]
    },
    "exportAnswer": {
      "properties": {
        "author": {
          "type": "string",
          "description": "Full name of the person who wrote this answer"
        },
        "text": {
          "type": "string",
          "description": "The answer text"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "author",
        "text"
      ]
    },
    "exportBadge": {
      "properties": {
        "id": {
          "type": "string",
          "description": "Badge event ID"
        },
        "date": {
          "type": "string",
          "description": "Date the recognition was given (ISO 8601)"
        },
        "from": {
          "type": "string",
          "description": "Full name of the person who gave the badge"
        },
        "to": {
          "type": "string",
          "description": "Full name of the person who received the badge"
        },
        "badge": {
          "type": "string",
          "description": "Name of the badge awarded"
        },
        "message": {
          "type": "string",
          "description": "Personal message included with the badge"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "date"
      ]
    },
    "exportCheckin": {
      "properties": {
        "id": {
          "type": "string",
          "description": "Check-in ID"
        },
        "date": {
          "type": "string",
          "description": "Date the check-in was posted (ISO 8601)"
        },
        "message": {
          "type": "string",
          "description": "Free-text update posted with this check-in"
        },
        "progress_at_checkin": {
          "type": "number",
          "description": "Progress percentage recorded at the time of this check-in"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "date"
      ]
    },
    "exportKR": {
      "properties": {
        "id": {
          "type": "string",
          "description": "Key result ID"
        },
        "name": {
          "type": "string",
          "description": "Key result title"
        },
        "description": {
          "type": "string",
          "description": "Optional longer description"
        },
        "progress": {
          "type": "number",
          "description": "Completion percentage (0–100)"
        },
        "measurement_type": {
          "type": "string",
          "description": "How progress is measured: percent, number, currency, or boolean"
        },
        "current_value": {
          "type": "number",
          "description": "Current measured value"
        },
        "target_value": {
          "type": "number",
          "description": "Target value to reach 100% completion"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "name",
        "progress",
        "current_value",
        "target_value"
      ]
    },
    "exportMeeting": {
      "properties": {
        "id": {
          "type": "string",
          "description": "1:1 meeting ID"
        },
        "date": {
          "type": "string",
          "description": "Scheduled date and time of the meeting (ISO 8601)"
        },
        "with": {
          "type": "string",
          "description": "Full name of the other participant"
        },
        "status": {
          "type": "string",
          "description": "Meeting status: completed or upcoming"
        },
        "questions": {
          "items": {
            "$ref": "#/$defs/exportQA"
          },
          "type": "array",
          "description": "Questions and answers from both participants"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "date",
        "with",
        "status"
      ]
    },
    "exportObjective": {
      "properties": {
        "id": {
          "type": "string",
          "description": "Objective ID"
        },
        "name": {
          "type": "string",
          "description": "Objective title"
        },
        "description": {
          "type": "string",
          "description": "Optional longer description of the objective"
        },
        "type": {
          "type": "string",
          "description": "Scope of the objective: personal, team, or org"
        },
        "participant_type": {
          "type": "string",
          "description": "The user's role on this objective: owner, stakeholder, or follower"
        },
        "progress": {
          "type": "number",
          "description": "Overall completion percentage (0–100)"
        },
        "start_date": {
          "type": "string",
          "description": "Objective start date (YYYY-MM-DD)"
        },
        "due_date": {
          "type": "string",
          "description": "Objective due date (YYYY-MM-DD)"
        },
        "completed_date": {
          "type": "string",
          "description": "Date the objective was marked complete (YYYY-MM-DD)"
        },
        "closed": {
          "type": "boolean",
          "description": "Whether the objective is closed (completed or abandoned)"
        },
        "key_results": {
          "items": {
            "$ref": "#/$defs/exportKR"
          },
          "type": "array",
          "description": "Key results nested under this objective"
        },
        "checkins": {
          "items": {
            "$ref": "#/$defs/exportCheckin"
          },
          "type": "array",
          "description": "Most recent progress check-in"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "name",
        "type",
        "progress",
        "closed"
      ]
    },
    "exportPeerQuestion": {
      "properties": {
        "question": {
          "type": "string",
          "description": "The peer feedback question text"
        },
        "answers": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "Anonymised answers submitted by peers"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "question"
      ]
    },
    "exportPeerReport": {
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the peer feedback request"
        },
        "published": {
          "type": "string",
          "description": "Date the curated report was published (ISO 8601)"
        },
        "questions": {
          "items": {
            "$ref": "#/$defs/exportPeerQuestion"
          },
          "type": "array",
          "description": "Questions with anonymised peer answers"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "title"
      ]
    },
    "exportQA": {
      "properties": {
        "question": {
          "type": "string",
          "description": "The question text"
        },
        "hint": {
          "type": "string",
          "description": "Optional guidance or sub-prompt shown under the question"
        },
        "answers": {
          "items": {
            "$ref": "#/$defs/exportAnswer"
          },
          "type": "array",
          "description": "Answers submitted by each participant"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "question",
        "answers"
      ]
    },
    "exportRecognition": {
      "properties": {
        "received": {
          "items": {
            "$ref": "#/$defs/exportBadge"
          },
          "type": "array",
          "description": "Badges the user received from others"
        },
        "given": {
          "items": {
            "$ref": "#/$defs/exportBadge"
          },
          "type": "array",
          "description": "Badges the user sent to others"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "received",
        "given"
      ]
    },
    "exportReview": {
      "properties": {
        "id": {
          "type": "integer",
          "description": "Performance review cycle ID"
        },
        "title": {
          "type": "string",
          "description": "Name of the review cycle (e.g. 'Q1 2026 Performance Review')"
        },
        "period": {
          "type": "string",
          "description": "Human-readable quarter label derived from the start date (e.g. Q1 2026)"
        },
        "start_date": {
          "type": "string",
          "description": "Review period start date (ISO 8601)"
        },
        "end_date": {
          "type": "string",
          "description": "Review period end date (ISO 8601)"
        },
        "state": {
          "type": "string",
          "description": "Workflow state of the review cycle"
        },
        "position": {
          "type": "string",
          "description": "The user's job title at the time of the review"
        },
        "manager": {
          "type": "string",
          "description": "Full name of the user's manager for this review"
        },
        "sections": {
          "items": {
            "$ref": "#/$defs/exportReviewSection"
          },
          "type": "array",
          "description": "Review form sections containing questions and answers"
        },
        "peer_feedback": {
          "$ref": "#/$defs/exportPeerReport",
          "description": "Curated peer feedback report if one was published for this cycle"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "title",
        "period",
        "start_date",
        "end_date",
        "state"
      ]
    },
    "exportReviewQA": {
      "properties": {
        "question": {
          "type": "string",
          "description": "The review question text"
        },
        "employee": {
          "type": "string",
          "description": "The employee's answer"
        },
        "manager": {
          "type": "string",
          "description": "The manager's response"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "question"
      ]
    },
    "exportReviewSection": {
      "properties": {
        "title": {
          "type": "string",
          "description": "Section heading"
        },
        "items": {
          "items": {
            "$ref": "#/$defs/exportReviewQA"
          },
          "type": "array",
          "description": "Questions and answers within this section"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "title",
        "items"
      ]
    },
    "exportUser": {
      "properties": {
        "id": {
          "type": "integer",
          "description": "7Geese user profile ID"
        },
        "name": {
          "type": "string",
          "description": "Full name"
        },
        "email": {
          "type": "string",
          "description": "Work email address"
        },
        "position": {
          "type": "string",
          "description": "Job title or position"
        },
        "hire_date": {
          "type": "string",
          "description": "Date the user joined the organisation (YYYY-MM-DD)"
        },
        "manager": {
          "type": "string",
          "description": "Full name of the user's direct manager"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "name"
      ]
    }
  }
}
